{
  "name": "algo-viz",
  "version": "1.1.2",
  "description": "排序算法可视化 - 桌面版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:dir": "electron-builder --dir",
    "clean": "node -e \"const fs=require('fs');const path=require('path');function rm(p){if(!fs.existsSync(p))return;try{fs.rmSync(p,{recursive:true,force:true,maxRetries:5,retryDelay:200});}catch(e){console.error('跳过:',p,e.message);}}['dist','build.log'].forEach(n=>rm(path.join(__dirname,n)));\""
  },
  "keywords": [
    "sorting",
    "algorithm",
    "visualization",
    "electron"
  ],
  "author": "Developer",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.example.algo-viz",
    "productName": "排序算法可视化",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "package.json",
      "index.html",
      "main.js",
      "preload.js",
      "styles.css",
      "src/**/*",
      "!**/*.md",
      "!**/.git*",
      "!**/.vscode/**",
      "!**/test/**",
      "!**/__tests__/**",
      "!**/test-*.js",
      "!**/debug-*.js",
      "!**/*.log",
      "!**/*.map",
      "!**/Thumbs.db",
      "!**/.DS_Store"
    ],
    "asar": true,
    "compression": "normal",
    "npmRebuild": false,
    "removePackageKeywords": true,
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "signingHashAlgorithms": [],
      "sign": false,
      "signAndEditExecutable": false,
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
